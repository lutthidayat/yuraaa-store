<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Yuraaa Finance</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}

body{
background:linear-gradient(180deg,#020617,#020617,#0f172a);
color:white;
}

/* HEADER */
.header{
padding:20px;
font-size:20px;
font-weight:bold;
text-align:center;
background:linear-gradient(90deg,#22c55e,#38bdf8);
-webkit-background-clip:text;
color:transparent;
}

/* CARD */
.card{
margin:12px;
padding:16px;
border-radius:20px;
background:rgba(255,255,255,0.04);
backdrop-filter:blur(12px);
box-shadow:0 6px 25px rgba(0,0,0,0.5);
}

/* BALANCE */
.balance{
font-size:28px;
font-weight:bold;
color:#22c55e;
}

/* LIST */
.item{
display:flex;
justify-content:space-between;
align-items:center;
padding:12px;
margin-top:8px;
border-radius:12px;
background:rgba(255,255,255,0.05);
}

/* INPUT */
input,select{
width:100%;
padding:12px;
margin-top:8px;
border-radius:12px;
border:none;
background:rgba(255,255,255,0.06);
color:white;
}

/* BUTTON */
button{
padding:12px;
border:none;
border-radius:12px;
background:linear-gradient(135deg,#22c55e,#16a34a);
color:white;
font-weight:bold;
width:100%;
}

/* TAB */
.tab{display:none;padding-bottom:90px;}
.tab.active{display:block;}

/* FAB */
.fab{
position:fixed;
bottom:85px;
right:20px;
width:65px;
height:65px;
border-radius:50%;
background:linear-gradient(135deg,#22c55e,#16a34a);
display:flex;
align-items:center;
justify-content:center;
font-size:30px;
box-shadow:0 0 30px rgba(34,197,94,0.6);
}

/* NAV */
.nav{
position:fixed;
bottom:0;
width:100%;
display:flex;
justify-content:space-around;
background:#020617;
padding:12px;
border-top:1px solid rgba(255,255,255,0.1);
}

.nav div{
opacity:0.5;
font-size:13px;
text-align:center;
}

.nav .active{
opacity:1;
color:#22c55e;
}

/* PROGRESS */
.progress{
width:160px;
height:160px;
border-radius:50%;
margin:auto;
display:flex;
align-items:center;
justify-content:center;
font-size:20px;
font-weight:bold;
background:conic-gradient(#22c55e 0%,#1e293b 0%);
box-shadow:0 0 40px rgba(34,197,94,0.4);
}

/* MODAL */
.modal{
position:fixed;
top:0;left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.7);
display:none;
align-items:center;
justify-content:center;
}

.modal-box{
background:#0f172a;
padding:20px;
border-radius:20px;
width:90%;
animation:fadeUp 0.3s ease;
}

@keyframes fadeUp{
from{opacity:0;transform:translateY(20px);}
to{opacity:1;transform:translateY(0);}
}
</style>
</head>

<body>

<div class="header">💸 Yuraaa Finance</div>

<!-- TAB 1 -->
<div id="home" class="tab active">

<div class="card">
<div class="balance" id="balance">Rp0</div>
</div>

<div class="card">
<canvas id="chart" height="120"></canvas>
</div>

<div class="card">
<h3>Riwayat</h3>
<div id="list"></div>
</div>

</div>

<!-- TAB 2 -->
<div id="targetTab" class="tab">

<div class="card">
<input id="target" placeholder="Target uang">
<div class="progress" id="progress">0%</div>
</div>

</div>

<!-- MODAL -->
<div class="modal" id="modal">
<div class="modal-box">

<select id="type">
<option value="income">Pemasukan</option>
<option value="expense">Pengeluaran</option>
</select>

<input id="desc" placeholder="Deskripsi">
<input id="amount" type="number" placeholder="Jumlah">

<select id="category">
<option>Jual Akun</option>
<option>Topup</option>
<option>Pribadi</option>
</select>

<button onclick="addData()">Simpan</button>
<button onclick="closeModal()">Tutup</button>

</div>
</div>

<!-- FAB -->
<div class="fab" onclick="openModal()">+</div>

<!-- NAV -->
<div class="nav">
<div class="active" onclick="switchTab('home',this)">🏠<br>Home</div>
<div onclick="switchTab('targetTab',this)">🎯<br>Target</div>
</div>

<script>
let data=JSON.parse(localStorage.getItem("data"))||[];
let savedTarget=localStorage.getItem("target")||0;

const list=document.getElementById("list");
const balance=document.getElementById("balance");
const progress=document.getElementById("progress");
const targetInput=document.getElementById("target");
const chartCanvas=document.getElementById("chart");

targetInput.value=savedTarget;

// TAB
function switchTab(id,el){
document.querySelectorAll(".tab").forEach(t=>t.classList.remove("active"));
document.getElementById(id).classList.add("active");

document.querySelectorAll(".nav div").forEach(n=>n.classList.remove("active"));
el.classList.add("active");
}

// MODAL
function openModal(){modal.style.display="flex";}
function closeModal(){modal.style.display="none";}

// FORMAT
function rp(x){return "Rp"+(x||0).toLocaleString("id-ID");}

// RENDER
function render(){
list.innerHTML="";
let income=0,expense=0;

data.forEach(d=>{
if(d.type=="income") income+=d.amount;
else expense+=d.amount;

let el=document.createElement("div");
el.className="item";
el.innerHTML=`
<div>
<b>${d.desc}</b><br>
<small>${d.category}</small>
</div>
<div style="color:${d.type=="income"?"#22c55e":"#ef4444"}">
${d.type=="income"?"+":"-"} ${rp(d.amount)}
</div>
`;
list.appendChild(el);
});

let total=income-expense;
balance.innerText=rp(total);

// chart
if(window.chart) chart.destroy();
window.chart=new Chart(chartCanvas,{
type:"bar",
data:{
labels:["Pemasukan","Pengeluaran"],
datasets:[{
data:[income,expense],
borderRadius:10
}]
},
options:{
plugins:{legend:{display:false}},
scales:{y:{beginAtZero:true}}
}
});

// progress
let t=parseInt(targetInput.value)||0;
let p=t?Math.min((total/t)*100,100):0;

progress.innerText=Math.floor(p)+"%";
progress.style.background=`conic-gradient(#22c55e ${p}%,#1e293b 0%)`;

localStorage.setItem("data",JSON.stringify(data));
localStorage.setItem("target",t);
}

// ADD
function addData(){
let d={
type:type.value,
desc:desc.value,
amount:parseInt(amount.value),
category:category.value
};

if(!d.desc||!d.amount)return alert("Isi dulu!");

data.push(d);
closeModal();
render();
}

// AUTO TARGET
targetInput.addEventListener("input",render);

render();
</script>

</body>
</html>